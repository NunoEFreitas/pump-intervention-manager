# Database (PostgreSQL)
# For Neon: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
# For Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://username:password@localhost:5432/pump_intervention_db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-this-in-production"

# JWT
JWT_SECRET="your-jwt-secret-here-change-this-in-production"

# Microsoft Graph API — email sending
# Setup: Azure Portal → Azure AD → App registrations → New registration
#   API permissions → Microsoft Graph → Application permissions → Mail.Send → Grant admin consent
#   Certificates & secrets → New client secret
MICROSOFT_TENANT_ID="your-tenant-id"
MICROSOFT_CLIENT_ID="your-client-id"
MICROSOFT_CLIENT_SECRET="your-client-secret"
MICROSOFT_SENDER_EMAIL="noreply@yourdomain.com"
