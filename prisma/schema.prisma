// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String         @id @default(uuid())
  reference               String?        @unique
  email                   String         @unique
  password                String
  name                    String
  role                    UserRole       @default(TECHNICIAN)
  blocked                 Boolean        @default(false)
  clientId                String?
  clientRef               Client?        @relation("ClientUsers", fields: [clientId], references: [id])
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  assignedInterventions   Intervention[] @relation("AssignedInterventions")
  createdInterventions    Intervention[] @relation("CreatedInterventions")
  warehouseItems          TechnicianStock[] @relation("TechnicianWarehouse")
  serialNumbers           SerialNumberStock[] @relation("TechnicianSerialNumbers")
  itemMovementsFrom       ItemMovement[] @relation("MovementFrom")
  itemMovementsTo         ItemMovement[] @relation("MovementTo")
  itemMovementsCreated    ItemMovement[] @relation("MovementCreatedBy")
  workOrdersCreated       WorkOrder[] @relation("WorkOrderCreatedBy")
  clientPartsPickedUp     SerialNumberStock[] @relation("ClientPartPickedUpBy")
  workOrderPartsUsed      WorkOrderPart[] @relation("WorkOrderPartUsedBy")

  @@index([role])
}

enum UserRole {
  ADMIN
  SUPERVISOR
  TECHNICIAN
  CLIENT
}

model Client {
  id            String            @id @default(uuid())
  reference     String?           @unique
  name          String
  vatNumber     String?
  country       String?
  district      String?
  address       String?
  city          String?
  postalCode    String?
  phone         String?
  email         String?
  contactPerson String?
  notes         String?           @db.Text
  contract      Boolean           @default(false)
  contractDate  DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  interventions Intervention[]
  locations     CompanyLocation[]
  users         User[]            @relation("ClientUsers")
}

model CompanyLocation {
  id            String              @id @default(uuid())
  clientId      String
  client        Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name          String
  country       String?
  district      String?
  address       String?
  city          String?
  postalCode    String?
  phone         String?
  contactPerson   String?
  notes           String?             @db.Text
  ovmRegulatorId  String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  interventions   Intervention[]
  equipment     LocationEquipment[]
}

model EquipmentType {
  id             String              @id @default(uuid())
  name           String              @unique
  createdAt      DateTime            @default(now())
  equipment      LocationEquipment[]
  warehouseItems WarehouseItem[]
}

model EquipmentBrand {
  id             String              @id @default(uuid())
  name           String              @unique
  createdAt      DateTime            @default(now())
  equipment      LocationEquipment[]
  warehouseItems WarehouseItem[]
}

model LocationEquipment {
  id              String          @id @default(uuid())
  locationId      String
  location        CompanyLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  equipmentTypeId String
  equipmentType   EquipmentType   @relation(fields: [equipmentTypeId], references: [id])
  brandId         String
  brand           EquipmentBrand  @relation(fields: [brandId], references: [id])
  model           String
  serialNumber    String?
  observations    String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Intervention {
  id               String              @id @default(uuid())
  reference        String?             @unique
  clientId         String
  client           Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  locationId       String?
  location         CompanyLocation?    @relation(fields: [locationId], references: [id])
  assignedToId     String?
  assignedTo       User?               @relation("AssignedInterventions", fields: [assignedToId], references: [id])
  createdById      String?
  createdBy        User?               @relation("CreatedInterventions", fields: [createdById], references: [id])
  status           InterventionStatus  @default(OPEN)
  scheduledDate    DateTime?
  scheduledTime    String?
  breakdown        String              @default("") @db.Text // Description of the breakdown/issue
  comments         String?             @db.Text             // Internal free-text comments
  bill             Boolean             @default(false)
  contract         Boolean             @default(false)
  warranty         Boolean             @default(false)
  partsUsed        InterventionPart[]  // Parts used in this intervention
  workOrders       WorkOrder[]
  clientParts      SerialNumberStock[] @relation("ClientPartSerialNumbers")
  photos           InterventionPhoto[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([clientId])
  @@index([assignedToId])
  @@index([status])
  @@index([scheduledDate])
}

// Track parts used in interventions
model InterventionPart {
  id              String        @id @default(uuid())
  interventionId  String
  intervention    Intervention  @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  itemId          String
  item            WarehouseItem @relation(fields: [itemId], references: [id])
  quantity        Int
  serialNumberIds String[]      // Array of serial number IDs if item tracks SNs
  createdAt       DateTime      @default(now())

  @@index([interventionId])
  @@index([itemId])
}

enum InterventionStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  QUALITY_ASSESSMENT
  COMPLETED
  CANCELED
}

model WarehouseItem {
  id                  String              @id @default(uuid())
  itemName            String
  partNumber          String
  ean13               String?             // EAN-13 barcode
  equipmentTypeId     String?
  equipmentType       EquipmentType?      @relation(fields: [equipmentTypeId], references: [id])
  brandId             String?
  brand               EquipmentBrand?     @relation(fields: [brandId], references: [id])
  value               Float
  mainWarehouse       Int                 @default(0)  // Count for non-serialized items
  repairStock         Int                 @default(0)  // Count of items currently in repair
  destructionStock    Int                 @default(0)  // Count of items in destruction
  tracksSerialNumbers Boolean             @default(false) // Whether this item uses SN tracking
  autoSn              Boolean             @default(false) // Auto-generate serial numbers on add stock
  snExample           String?             // Prefix for auto-generated SNs (e.g. "PTT" → "PTT-1", "PTT-2")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  movements           ItemMovement[]
  technicianStocks    TechnicianStock[]
  serialNumbers       SerialNumberStock[]
  interventionParts   InterventionPart[]
  workOrderParts      WorkOrderPart[]
  inventoryEntries    InventoryEntry[]
}

model TechnicianStock {
  id              String          @id @default(uuid())
  itemId          String
  item            WarehouseItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  technicianId    String
  technician      User            @relation("TechnicianWarehouse", fields: [technicianId], references: [id], onDelete: Cascade)
  quantity        Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@unique([itemId, technicianId])
}

model ItemMovement {
  id              String                  @id @default(uuid())
  itemId          String
  item            WarehouseItem           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  movementType    MovementType
  quantity        Int
  fromUserId      String?
  fromUser        User?                   @relation("MovementFrom", fields: [fromUserId], references: [id])
  toUserId        String?
  toUser          User?                   @relation("MovementTo", fields: [toUserId], references: [id])
  notes           String?                 @db.Text
  createdById     String
  createdBy       User                    @relation("MovementCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime                @default(now())
  serialNumbers   MovementSerialNumber[]  // Track which SNs were moved
}

enum MovementType {
  ADD_STOCK             // Add to main warehouse
  REMOVE_STOCK          // Remove from main warehouse (loss, damage, etc)
  TRANSFER_TO_TECH      // Transfer from main to technician
  TRANSFER_FROM_TECH    // Return from technician to main
  USE                   // Used in intervention
  REPAIR_IN             // Sent to repair (removed from active stock)
  REPAIR_OUT            // Returned from repair (back to main warehouse)
  DESTRUCTION           // Moved to destruction stock (irreparable)
  INVENTORY_ADJUSTMENT  // Stock correction after inventory count
}

// Track individual serial numbers for items
model SerialNumberStock {
  id              String                  @id @default(uuid())
  itemId          String
  item            WarehouseItem           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  serialNumber    String                  // The actual serial number
  location        StockLocation           @default(MAIN_WAREHOUSE)
  technicianId    String?
  technician      User?                   @relation("TechnicianSerialNumbers", fields: [technicianId], references: [id])
  status          SerialStatus            @default(AVAILABLE)
  isClientPart      Boolean                 @default(false)  // Part taken from client site for repair
  clientPartStatus  ClientPartStatus?                        // Only when isClientPart=true
  clientRepairJobId String?                                  // Link to PartRepairJob when CLIENT repair opened
  interventionId    String?
  intervention      Intervention?           @relation("ClientPartSerialNumbers", fields: [interventionId], references: [id])
  pickedUpById      String?
  pickedUpBy        User?                   @relation("ClientPartPickedUpBy", fields: [pickedUpById], references: [id])
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  movements         MovementSerialNumber[]

  @@unique([itemId, serialNumber]) // Serial number must be unique per item
  @@index([itemId])
  @@index([technicianId])
  @@index([location])
  @@index([isClientPart])
  @@index([clientPartStatus])
}

enum StockLocation {
  MAIN_WAREHOUSE
  TECHNICIAN
  USED
  REPAIR
  DESTRUCTION
}

enum SerialStatus {
  AVAILABLE
  IN_USE
  DAMAGED
  LOST
}

enum ClientPartStatus {
  PENDING   // Awaiting decision (swap or repair)
  SWAP      // Swap chosen — replacement issued to technician
  REPAIR    // Client repair job opened
  RESOLVED  // Returned to client
}

// Join table for movements and serial numbers
model MovementSerialNumber {
  id              String            @id @default(uuid())
  movementId      String
  movement        ItemMovement      @relation(fields: [movementId], references: [id], onDelete: Cascade)
  serialNumberId  String
  serialNumber    SerialNumberStock @relation(fields: [serialNumberId], references: [id], onDelete: Cascade)

  @@unique([movementId, serialNumberId])
}

model WorkOrder {
  id             String          @id @default(uuid())
  interventionId String
  intervention   Intervention    @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  reference             String?         @unique
  description           String          @db.Text
  timeSpent             Float?
  km                    Float?
  locationEquipmentId   String?
  interventionType      String?
  transportGuide        String?
  fromAddress           String?
  internal              Boolean         @default(false)
  createdById           String
  createdBy      User            @relation("WorkOrderCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  parts          WorkOrderPart[]
  sessions       WorkOrderSession[]

  @@index([interventionId])
}

model WorkOrderSession {
  id          String    @id @default(uuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  startDate   String?
  startTime   String?
  endDate     String?
  endTime     String?
  duration    Float?    // hours for this session
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workOrderId])
}

model WorkOrderVehicle {
  id          String   @id @default(uuid())
  workOrderId String
  vehicleId   String
  createdAt   DateTime @default(now())

  @@unique([workOrderId, vehicleId])
}

model WorkOrderHelper {
  id          String   @id @default(uuid())
  workOrderId String
  userId      String
  createdAt   DateTime @default(now())

  @@unique([workOrderId, userId])
}

model WorkOrderPart {
  id              String        @id @default(uuid())
  workOrderId     String
  workOrder       WorkOrder     @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  itemId          String
  item            WarehouseItem @relation(fields: [itemId], references: [id])
  quantity        Int
  serialNumberIds String[]
  usedById        String?
  usedBy          User?         @relation("WorkOrderPartUsedBy", fields: [usedById], references: [id])
  createdAt       DateTime      @default(now())

  @@index([workOrderId])
  @@index([itemId])
}

model CompanyVehicle {
  id          String   @id @default(uuid())
  plateNumber String   @unique
  brand       String?
  model       String?
  description String?
  createdAt   DateTime @default(now())
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model WorkOrderPDF {
  id              String   @id @default(uuid())
  workOrderId     String
  clientSignature String?
  techSignature   String?
  createdAt       DateTime @default(now())

  @@index([workOrderId])
}

model OVM {
  id             String   @id @default(uuid())
  interventionId String
  data           Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([interventionId])
}

model InventorySession {
  id           String           @id @default(uuid())
  type         String           // 'WAREHOUSE' | 'TECHNICIAN'
  technicianId String?
  status       String           @default("OPEN") // OPEN | PENDING_APPROVAL | CLOSED | CANCELLED
  notes        String?          @db.Text
  createdById  String
  closedById   String?
  createdAt    DateTime         @default(now())
  closedAt     DateTime?
  entries      InventoryEntry[]

  @@index([status])
  @@index([type])
}

model InventoryEntry {
  id                 String                 @id @default(uuid())
  sessionId          String
  session            InventorySession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  itemId             String
  item               WarehouseItem          @relation(fields: [itemId], references: [id])
  expectedQty        Int
  countedQty         Int?
  correctionApproved Boolean?
  notes              String?
  serials            InventoryEntrySerial[]

  @@unique([sessionId, itemId])
  @@index([sessionId])
}

model InventoryEntrySerial {
  id             String         @id @default(uuid())
  entryId        String
  entry          InventoryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  serialNumberId String

  @@unique([entryId, serialNumberId])
  @@index([entryId])
}

model FuelType {
  id           String   @id @default(uuid())
  translations Json     // { en: string, pt: string, es: string }
  createdAt    DateTime @default(now())
}

model OvmRegulator {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
}

model InterventionPhoto {
  id             String       @id @default(uuid())
  interventionId String
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  filename       String
  mimeType       String
  data           String       @db.Text
  createdAt      DateTime     @default(now())
  createdById    String?

  @@index([interventionId])
}

model PartRequest {
  id               String   @id @default(uuid())
  interventionId   String
  requestedById    String
  warehouseItemId  String
  quantity         Int      @default(1)
  notes            String?
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([interventionId])
  @@index([status])
}

enum RepairJobType {
  STOCK   // Repairing our own stock item (REP prefix)
  CLIENT  // Repairing a client's part (REC prefix)
}

// Tracks individual parts sent to repair (created automatically on REPAIR_IN movement)
model PartRepairJob {
  id               String        @id @default(uuid())
  reference        String?       @unique    // e.g. REP-001/2025 or REC-001/2025
  type             RepairJobType @default(STOCK)
  itemId           String                   // WarehouseItem
  serialNumberId   String?                  // For SN-tracked items — one job per SN
  clientPartId     String?                  // SerialNumberStock.id when type=CLIENT
  interventionId   String?                  // CLIENT: intervention where the part was collected
  quantity         Int           @default(1) // For non-SN items
  status           String        @default("PENDING")
  // STOCK:  PENDING | IN_REPAIR | REPAIRED | WRITTEN_OFF
  // CLIENT: PENDING | IN_REPAIR | QUOTE | RETURNED_TO_CLIENT | NOT_REPAIRED
  clientItemSn     String?                  // CLIENT: serial number of the client's item (free text)
  problem          String?       @db.Text   // Problem description
  conditionDescription String?   @db.Text   // Item condition on arrival
  hasAccessories   Boolean       @default(false)  // Whether accessories were included
  accessoriesDescription String? @db.Text   // Accessories description
  workNotes        String?       @db.Text   // What was done during repair
  repairedByTechId String?                  // Technician who performed the repair
  quoteAmount      Decimal?      @db.Decimal(10, 2)  // Budget amount
  quoteNotes       String?       @db.Text             // Quote description
  quoteStatus      String?       // null | PENDING_CLIENT | ACCEPTED | REJECTED
  quotedAt         DateTime?
  sentAt           DateTime      @default(now())
  completedAt      DateTime?
  deliveredToClientId String?               // CLIENT type: which client
  sentById         String
  completedById    String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  photos           RepairJobPhoto[]
  parts            RepairJobPart[]

  @@index([itemId])
  @@index([status])
  @@index([type])
  @@index([serialNumberId])
  @@index([clientPartId])
}

model RepairJobPart {
  id          String        @id @default(uuid())
  jobId       String
  job         PartRepairJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  itemId      String
  quantity    Int
  notes       String?
  addedById   String
  addedAt     DateTime      @default(now())

  @@index([jobId])
  @@index([itemId])
}

model RepairJobPhoto {
  id          String        @id @default(uuid())
  jobId       String
  job         PartRepairJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  filename    String
  mimeType    String
  data        String        @db.Text
  createdAt   DateTime      @default(now())
  createdById String?

  @@index([jobId])
}
